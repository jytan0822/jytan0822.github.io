@article{caner2026designing,
  title={Designing Agentic AI-Based Screening for Portfolio Investment},
  author={Caner, Mehmet and Capponi, Agostino and Sun, Nathan and Tan, Jonathan Y},
  journal={Preprint},
  abstract{We introduce a new agentic artificial intelligence (AI) platform for portfolio management. Our architecture consists of three layers. First, two large language model (LLM) agents are assigned specialized tasks: one agent screens for firms with desirable fundamentals, while a sentiment analysis agent screens for firms with desirable news. Second, these agents deliberate to generate and agree upon buy and sell signals from a large portfolio, substantially narrowing the pool of candidate assets. Finally, we apply a high-dimensional precision matrix estimation procedure to determine optimal portfolio weights. A defining theoretical feature of our framework is that the number of assets in the portfolio is itself a random variable, realized through the screening process. We introduce the concept of sensible screening and establish that, under mild screening errors, the squared Sharpe ratio of the screened portfolio consistently estimates its target. Empirically, our method achieves superior Sharpe ratios relative to an unscreened baseline portfolio and to conventional screening approaches, evaluated on S&P 500 data over the period 2020--2024.},
  arxiv={https://arxiv.org/abs/2603.23300},
  year={2026},
  selected={true}
}

@article{elmachtoub2026learning,
  title={Learning Fair Demand Models},
  author={Elmachtoub, Adam and Kim, Hyemi and Tan, Jonathan Y},
  journal={Preliminary version accepted by ACM FAccT 2026},
  abstract={Data-driven personalized pricing systems are now widely used across sectors such as airlines, insurance, mobility platforms, and retail. These systems learn demand models and tailor prices using customer features resulting in discriminatory outcomes that may be perceived as unfair. This raises a fundamental question -- how should systems incorporate fairness considerations in the pricing pipeline, and how does it ultimately affect outcomes? To answer this, we study fairness interventions in a two-stage pricing pipeline comprising of demand estimation and price optimization. Considering a stylized model where there are two groups of consumers and demand is linear in price, we study fairness in training loss, price, and demand under parity-wise and Rawlsian perspectives. We show that equalizing training loss across groups can lead to two optimal solutions with distinct welfare implications, making downstream outcomes highly sensitive to solution choice. Focusing instead on fairness applied directly to prices or demand, we compare Fair-Estimate-then-Optimize (FEO), which enforces fairness during demand estimation, and Estimate-then-Fair-Optimize (EFO), which enforces fairness during price optimization. Under parity-wise fairness, a single threshold determines which approach yields higher welfare for price and demand fairness, implying that neither approach is universally superior. On the contrary, the two approaches coincide under Rawlsian fairness. Lastly, a case study using real-world vaccine pricing data closely mirrors these theoretical findings across both linear and logistic demand models with personalized features.},
  year = {2026},
  selected={true}
}
